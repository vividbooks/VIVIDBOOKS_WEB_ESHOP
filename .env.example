# Zkopíruj na .env pro lokální vývoj (nepushuj .env do gitu).

# Trial stránka — skrytý nástroj: odkaz „Dev (JSON)“ u IČO (school-pipedrive-check + pipedriveApi).
# Zapnutí: VITE_SHOW_PIPEDRIVE_ICO_DEBUG=true nebo na stránce ?pipedriveDebug=1
# Ručně: …/school-pipedrive-check?ico=75015692&includePipedriveRaw=1
# VITE_SHOW_PIPEDRIVE_ICO_DEBUG=true

# Stripe — publishable klíč pro Payment Element (veřejný, může být i v CI).
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Zásilkovna widget (pokladna / školní objednávka).
VITE_PACKETA_API_KEY=

# Volitelně: Twitter @ pro og:twitter:site (bez @).
# VITE_TWITTER_SITE=vividbooks

# --- Mailchimp (jen Supabase Edge Function secrets, NE do Vite .env) ---
# Dashboard: Project Settings → Edge Functions → Secrets, nebo: supabase secrets set …
# MAILCHIMP_API_KEY=xxxxxxxx-us19
# MAILCHIMP_AUDIENCE_NEWSLETTER=list_id_pro_newsletter
# MAILCHIMP_AUDIENCE_NO_NEWSLETTER=list_id_pro_bez_newsletteru

# --- Externí RAG API (partner, např. Ninjabot) ---
# POST …/functions/v1/make-server-93a20b6f/external/rag-query
# Tělo: {"query":"..."}  ·  Hlavička: X-API-Key: <stejná hodnota jako níže>
# NINJABOT_RAG_API_KEY=vygeneruj-dlouhy-nahodny-retezec
# (alternativa: RAG_EXTERNAL_API_KEY — použije se, pokud NINJABOT_RAG_API_KEY není nastaveno)
